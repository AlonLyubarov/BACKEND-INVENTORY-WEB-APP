# JWT Configuration
# Provide a strong secret key (minimum 64 characters recommended)
Jwt__Key=your-super-secret-key-that-is-longer-than-32-characters-recommended-64-chars-minimum
Jwt__Issuer=AlonProject
Jwt__Audience=AlonProjectUsers

# Database Configuration
# SQL Server connection string
ConnectionStrings__SqlServer=Server=(localdb)\MSSQLLocalDB;Database=AlonInventoryDb;Trusted_Connection=true;TrustServerCertificate=true;

# Environment
# Set to Development for development environment, Production for production
ASPNETCORE_ENVIRONMENT=Development

# Test credentials (for local development only)
# Username: testuser
# Password: password123

# Email (SMTP) Configuration
# Leave Host empty for development (emails are logged instead of sent)
# For Gmail: use smtp.gmail.com with an App Password (not your regular password)
Email__Host=
Email__Port=587
Email__UseSsl=true
Email__Username=your-email@example.com
Email__Password=your-smtp-app-password
Email__From=your-email@example.com

# Geocoding/routing providers (Nominatim & OSRM) require a contact email in the User-Agent
Geo__ContactEmail=your-contact-email@example.com
